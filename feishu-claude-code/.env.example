# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_OPEN_ID=ou_xxxxxxxxxxxxx  # 你的个人飞书 open_id，用于接收 Harness pipeline 提醒

# Copilot 默认配置
CLI_BACKEND=copilot
DEFAULT_MODEL=gpt-5.4
DEFAULT_CWD=.. # 相对 feishu-claude-code 目录，指向当前 harness 工程

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）卡片按钮回调公网地址；已自建反向代理/隧道时可直接配置
# CALLBACK_PUBLIC_URL=https://your-domain.example.com

# （可选）本地卡片回调服务端口；未配置 CALLBACK_PUBLIC_URL 时可配合 ngrok 使用
# CALLBACK_PORT=9981

# （可选）Copilot CLI 路径，留空则自动从 PATH 查找
# COPILOT_CLI_PATH=/opt/homebrew/bin/copilot
# （兼容旧环境）Claude CLI 路径
# CLAUDE_CLI_PATH=/usr/local/bin/claude
